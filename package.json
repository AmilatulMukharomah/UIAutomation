{
    "name": "selenium-mocha-digital-skola",
    "version": "1.0.0",
    "description": "Selenium WebDriver tests using Mocha with Mochawesome reports",
    "scripts": {
      "test": "mocha tests/sesi9/test_sesi9.js --recursive --timeout 60000",
      "report": "mocha tests/sesi9/test_sesi9.js --recursive --timeout 60000 --reporter mochawesome"
    },
    "dependencies": {
      "selenium-webdriver": "^4.17.0"
    },
    "devDependencies": {
      "mocha": "^10.4.0",
      "mochawesome": "^7.1.3",
      "mocha-simple-html-reporter": "^2.0.0"
    }
  }
  
  